generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String
  role           String
  studentCode    String?         @unique
  schoolId       String?
  emailVerified  Boolean         @default(false)
  avatarUrl      String?
  createdAt      DateTime        @default(now())
  school         School?         @relation(fields: [schoolId], references: [id])
  passwordResets PasswordReset[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [email], references: [email])
}

model School {
  id      String  @id @default(cuid())
  name    String
  classes Class[]
  users   User[]
}

model Class {
  id          String            @id @default(cuid())
  name        String
  schoolId    String
  lecturerId  String
  school      School            @relation(fields: [schoolId], references: [id])
  sessions    MarkingSession[]
  enrollments ClassEnrollment[]
}

model ClassEnrollment {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])
}

model MarkingSession {
  id                String               @id @default(cuid())
  name              String
  classId           String?
  lecturerId        String
  subject           String
  sessionType       String
  examBoard         String
  courseId          String
  questionPdfUrl    String
  markSchemePdfUrl  String
  markingStrictness String               @default("Standard")
  feedbackDetail    String               @default("Detailed")
  status            String               @default("PENDING")
  createdAt         DateTime             @default(now())
  class             Class?               @relation(fields: [classId], references: [id])
  results           StudentResult[]
  answerSheets      StudentAnswerSheet[]
}

model StudentAnswerSheet {
  id            String         @id @default(cuid())
  sessionId     String
  studentId     String
  studentName   String?
  pdfUrl        String
  extractedText String
  extractMethod String
  status        String         @default("PENDING")
  createdAt     DateTime       @default(now())
  session       MarkingSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, studentId])
}

model StudentResult {
  id           String           @id @default(cuid())
  sessionId    String
  studentId    String
  studentName  String?
  studentCode  String?
  answerPdfUrl String
  totalMarks   Int
  maxMarks     Int
  percentage   Float
  grade        String
  reviewed     Boolean          @default(false)
  aiData       Json
  reportPdfUrl String?
  createdAt    DateTime         @default(now())
  questions    QuestionResult[]
  session      MarkingSession   @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, studentId])
}

model QuestionResult {
  id                    String        @id @default(cuid())
  studentResultId       String
  questionNumber        String
  topic                 String
  marksAwarded          Int
  marksAvailable        Int
  status                String
  aiFeedback            String
  lostMarksReason       String?
  improvementSuggestion String
  lecturerOverride      Int?
  lecturerNote          String?
  studentResult         StudentResult @relation(fields: [studentResultId], references: [id])
}
